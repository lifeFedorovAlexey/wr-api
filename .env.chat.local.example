DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/wr_api
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
USER_SESSION_SECRET=local-user-secret
WR_CHAT_SHARED_SECRET=local-chat-secret

# Optional local asset settings if you need the rest of the site alongside chat.
GUIDES_SYNC_SECRET=replace-me
ASSET_PUBLIC_MODE=s3
S3_ENDPOINT=https://s3.twcstorage.ru
S3_BUCKET=replace-me
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://your-public-bucket.example.com
