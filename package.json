{
  "name": "wr-api",
  "version": "1.2.3",
  "private": true,
  "description": "Public Wild Rift API",
  "type": "module",
  "scripts": {
    "start": "node ./server.mjs",
    "dev": "node --watch ./server.mjs",
    "start:public": "node ./server-public.mjs",
    "start:auth": "node ./server-auth.mjs",
    "start:gateway": "node ./server-gateway.mjs",
    "lint": "eslint .",
    "dup:check": "jscpd --config .jscpd.json",
    "audit:prod": "npm audit --omit=dev",
    "import:champions": "node ./scripts/import-champions.mjs",
    "import:riftgg-cn-stats": "node ./scripts/import-riftgg-cn-stats.mjs",
    "setup:stats": "node ./scripts/setup-stats-table.mjs",
    "setup:guides": "node ./scripts/setup-guides-table.mjs",
    "setup:admin": "node ./scripts/setup-admin-tables.mjs",
    "setup:chat": "node ./scripts/setup-chat-tables.mjs",
    "setup:riftgg-cn-stats": "node ./scripts/setup-riftgg-cn-stats-table.mjs",
    "setup:news": "node ./scripts/setup-news-tables.mjs",
    "export:news-mapper": "node ./scripts/export-news-entity-mapper.mjs",
    "audit:guides:ui": "node ./scripts/audit-guides-ui-e2e.mjs",
    "audit:guides:live": "node ./scripts/audit-guides-ui-e2e.mjs --ui-origin https://wildriftallstats.ru --api-origin https://wildriftallstats.ru/wr-api",
    "test": "node --test ./test",
    "test:coverage": "c8 npm run test",
    "sync:assets:s3": "node ./scripts/sync-assets-to-s3.mjs",
    "backfill:guide-entity-assets": "node ./scripts/backfill-guide-entity-assets.mjs",
    "backfill:profile-rank-assets": "node ./scripts/backfill-profile-rank-assets.mjs"
  },
  "overrides": {
    "basic-ftp": "5.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "basic-ftp": "5.2.2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "tsx": "^4.21.0"
  }
}
