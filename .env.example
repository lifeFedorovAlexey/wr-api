# Core database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/wr_api

# Asset delivery
GUIDES_SYNC_SECRET=replace-me
ASSET_PUBLIC_MODE=s3
S3_ENDPOINT=https://s3.twcstorage.ru
S3_BUCKET=replace-me
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://your-public-bucket.example.com

# Admin auth
# Must match the same value in ui/.env.local
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Public user auth
# Keep disabled until ui/.env.local also has USER_AUTH_ENABLED=true and the same USER_SESSION_SECRET.
USER_SESSION_SECRET=replace-with-a-separate-long-random-secret

# Bootstrap only for the very first owner account.
# After the first owner signs in, roles should be managed in the database.
ADMIN_BOOTSTRAP_EMAILS=you@example.com

# Deploy
# These are usually configured as GitHub repository secrets, not local .env values.
# TIMEWEB_HOST=
# TIMEWEB_USER=
# TIMEWEB_PASSWORD=

# Current production/staging secret set for the wr-api repo is limited to:
# ADMIN_BOOTSTRAP_EMAILS
# ADMIN_SESSION_SECRET
# ASSET_PUBLIC_MODE
# DATABASE_URL
# GUIDES_SYNC_SECRET
# S3_ACCESS_KEY_ID
# S3_BUCKET
# S3_ENDPOINT
# S3_FORCE_PATH_STYLE
# S3_PUBLIC_BASE_URL
# S3_SECRET_ACCESS_KEY
# TIMEWEB_HOST
# TIMEWEB_PASSWORD

# When public user auth is intentionally enabled, also add USER_SESSION_SECRET
# to the wr-api GitHub repo secrets and to the deployed server .env.
# TIMEWEB_USER

# The following env keys exist in code as optional/internal knobs or unfinished work,
# but they are not part of the current approved production secret inventory:
# ADMIN_BOOTSTRAP_TELEGRAM_IDS
# ADMIN_BOOTSTRAP_TELEGRAM_USERNAMES
# ADMIN_BOOTSTRAP_VK_IDS
# CHAMPIONS_SYNC_SECRET
# CHAMPIONS_SYNC_TOKEN
# NEWS_SYNC_SECRET
# NEWS_SYNC_TOKEN
# TELEGRAM_BOT_TOKEN
