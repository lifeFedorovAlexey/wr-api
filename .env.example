# Core database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/wr_api

# Existing wr-api settings
GUIDES_SYNC_SECRET=replace-me
ASSET_PUBLIC_MODE=s3
S3_PUBLIC_BASE_URL=https://your-public-bucket.example.com

# Admin auth
# Must match the same value in ui/.env.local
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Bootstrap only for the very first owner account.
# After the first owner signs in, roles should be managed in the database.
ADMIN_BOOTSTRAP_EMAILS=you@example.com
# ADMIN_BOOTSTRAP_TELEGRAM_IDS=123456789
# ADMIN_BOOTSTRAP_TELEGRAM_USERNAMES=your_username
